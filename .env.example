# Copia in `notebooklm.env` e compila. NON committare il file con i segreti reali.

# --- Notion (CMS) ---
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxx
NOTION_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PODCAST_DB_ID=

# --- LLM ---
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx
OPENROUTER_MODEL=openai/gpt-oss-120b:free
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Ricerca / scraping articoli ---
TAVILY_API_KEY=tvly-xxxxxxxx
FIRECRAWL_API_KEY=fc-xxxxxxxx

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxx
MAIL_FROM=onboarding@resend.dev
MAIL_TO=tu@example.com

# --- Brief (override dei default in blog.config.json) ---
BRIEF_TOTALE=7
BRIEF_MUSICA=2

# --- Pulizia automatica ---
CLEANUP_DAYS=3

# --- Podcast: TTS ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2
PODCAST_MAX_CHARS=2400
PODCAST_DAYS=7
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_VOICE=it-IT-Chirp3-HD-Aoede
PODCAST_VOICE=it-IT-IsabellaNeural

# --- Podcast: sottofondo musicale (ffmpeg) ---
PODCAST_BG_MUSIC=
PODCAST_INTRO_SEC=4
PODCAST_MUSIC_VOLUME=0.30

# --- Podcast: hosting audio (Internet Archive) ---
ARCHIVE_ACCESS_KEY=
ARCHIVE_SECRET_KEY=
ARCHIVE_COLLECTION=opensource_audio

# --- Trigger server ---
TRIGGER_TOKEN=cambiami
TRIGGER_PORT=80

# --- Config blog (config-driven): punta a un altro JSON per un blog diverso ---
# BLOG_CONFIG=/opt/notebooklm/blog.config.json
