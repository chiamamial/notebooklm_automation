# Copia questo file in /opt/notebooklm/notebooklm.env e compila i valori.
# NON committarlo: contiene segreti.

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
MAIL_FROM=onboarding@resend.dev
MAIL_TO=chiamamial93@gmail.com

# Parametri ricerca (opzionali)
RESEARCH_MODE=fast
RESEARCH_TIMEOUT=600
REPORT_LANGUAGE=it

# Notion (per il cruscotto news + generazione articoli on-demand)
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxx
NOTION_DB_ID=234c80b5af8546f38b1b1fc866b876f1

# --- Podcast settimanale (KANRI Audio) ---
# TTS principale: ElevenLabs (piano free, NESSUNA carta). 10.000 caratteri/mese:
# tieni le puntate brevi (~2 min). Chiave da https://elevenlabs.io (Profile -> API key).
ELEVENLABS_API_KEY=
# voice_id da scegliere nella Voice Library di ElevenLabs (preferisci una voce italiana)
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2
# Tetto caratteri per puntata (protegge la quota mensile)
PODCAST_MAX_CHARS=2400
PODCAST_DAYS=7
# Fallback (opzionali): Google Cloud Chirp 3 HD
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_VOICE=it-IT-Chirp3-HD-Aoede
# Fallback finale edge-tts (gratis, nessuna chiave)
PODCAST_VOICE=it-IT-IsabellaNeural
# ID del database Notion "Podcast" (vuoto = salta il salvataggio metadati)
PODCAST_DB_ID=
# Internet Archive (hosting audio gratuito): chiavi S3 da https://archive.org/account/s3.php
ARCHIVE_ACCESS_KEY=
ARCHIVE_SECRET_KEY=
ARCHIVE_COLLECTION=opensource_audio
